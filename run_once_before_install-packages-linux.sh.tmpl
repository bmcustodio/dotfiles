{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash
set -euo pipefail

# Core
sudo apt-get update -y
sudo apt-get install -y curl git zsh

# bat
sudo apt-get install -y bat
# Create symlink if batcat exists but bat doesn't.
if command -v batcat &>/dev/null && ! command -v bat &>/dev/null; then
  mkdir -p ~/.local/bin
  ln -sf "$(which batcat)" ~/.local/bin/bat
fi

# btop
sudo apt-get install -y btop

# eza
if ! command -v eza &>/dev/null; then
  sudo mkdir -p /etc/apt/keyrings
  wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc | sudo gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
  echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" | sudo tee /etc/apt/sources.list.d/gierens.list
  sudo chmod 644 /etc/apt/keyrings/gierens.gpg /etc/apt/sources.list.d/gierens.list
  sudo apt-get update -y
fi
sudo apt-get install -y eza

# fd (named fd-find on Debian/Ubuntu)
sudo apt-get install -y fd-find
# Create symlink if fdfind exists but fd doesn't.
if command -v fdfind &>/dev/null && ! command -v fd &>/dev/null; then
  mkdir -p ~/.local/bin
  ln -sf "$(which fdfind)" ~/.local/bin/fd
fi

# ripgrep
sudo apt-get install -y ripgrep

# fzf
sudo apt-get install -y fzf

# zoxide
if ! command -v zoxide &>/dev/null; then
  curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
fi

# atuin
if ! command -v atuin &>/dev/null; then
  curl --proto '=https' --tlsv1.2 -LsSf https://setup.atuin.sh | sh
fi

# starship
if ! command -v starship &>/dev/null; then
  curl -sS https://starship.rs/install.sh | sh -s -- -y
fi

# chezmoi
if ! command -v chezmoi &>/dev/null; then
  sh -c "$(curl -fsLS get.chezmoi.io)" -- -b ~/.local/bin
fi

# tmux
sudo apt-get install -y tmux

# direnv
sudo apt-get install -y direnv

# neovim
if ! command -v nvim &>/dev/null; then
  NVIM_ARCH="$(uname -m)"
  [[ "$NVIM_ARCH" == "aarch64" ]] && NVIM_ARCH="arm64"
  NVIM_TARBALL="nvim-linux-${NVIM_ARCH}.tar.gz"
  curl -LO "https://github.com/neovim/neovim/releases/latest/download/${NVIM_TARBALL}"
  sudo rm -rf "/opt/nvim-linux-${NVIM_ARCH}"
  sudo tar -C /opt -xzf "${NVIM_TARBALL}"
  sudo ln -sf "/opt/nvim-linux-${NVIM_ARCH}/bin/nvim" /usr/local/bin/nvim
  rm "${NVIM_TARBALL}"
fi
{{ end -}}
