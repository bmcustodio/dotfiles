# ----
# PATH
# ----

[[ -d /opt/homebrew/bin ]] && export PATH="/opt/homebrew/bin:$PATH"
[[ -d $HOME/.cargo/bin  ]] && export PATH="$HOME/.cargo/bin:$PATH"
[[ -d $HOME/go/bin      ]] && export PATH="$HOME/go/bin:$PATH"
[[ -d $HOME/.local/bin  ]] && export PATH="$HOME/.local/bin:$PATH"

# ---
# fzf
# ---

_fzf_opts=(
  --color=bg+:#313244,bg:#1E1E2E,spinner:#F5E0DC,hl:#F38BA8
  --color=fg:#CDD6F4,header:#F38BA8,info:#CBA6F7,pointer:#F5E0DC
  --color=marker:#B4BEFE,fg+:#CDD6F4,prompt:#CBA6F7,hl+:#F38BA8
  --color=selected-bg:#45475A
  --color=border:#6C7086,label:#CDD6F4
  --layout=reverse
  --popup=center
  --style=full
)

export FZF_DEFAULT_OPTS="${_fzf_opts[*]}"

# ----------
# oh-my-zsh
# ----------

export ZSH="$HOME/.oh-my-zsh"

plugins=(
  alias-finder
  direnv
  eza
  fzf
  fzf-tab
  git
  kubectl
  tmux
  zoxide
  zsh-autosuggestions
  zsh-syntax-highlighting
)
ZSH_THEME=""

zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':completion:*' menu no
zstyle ':fzf-tab:*' fzf-flags ${_fzf_opts[@]}
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
zstyle ':omz:plugins:eza' 'dirs-first' yes
zstyle ':omz:plugins:eza' 'git-status' yes
zstyle ':omz:plugins:eza' 'icons' yes
zstyle ':omz:update' frequency 7
zstyle ':omz:update' mode reminder

{{- if eq .profile "full" }}
export ZSH_TMUX_AUTOSTART=true
export ZSH_TMUX_UNICODE=true
{{- end }}

source "$ZSH/oh-my-zsh.sh"

# -------
# History
# -------

HISTFILE="${XDG_STATE_HOME:-$HOME/.local/state}/zsh/history"
HISTSIZE=2147483647
SAVEHIST=2147483647
mkdir -p "${HISTFILE:h}"

# -------
# Aliases
# -------

command -v bat  &>/dev/null && alias cat='bat'
command -v btop &>/dev/null && alias top='btop'
command -v nvim &>/dev/null && alias vi='nvim' && alias vim='nvim'
command -v rg   &>/dev/null && alias grep='rg'

# -----
# Tools
# -----

source "${XDG_CONFIG_HOME:-$HOME/.config}/atuin/atuin.zsh"
command -v nvim     &>/dev/null && export EDITOR='nvim' && export VISUAL='nvim'
command -v rg       &>/dev/null && export RIPGREP_CONFIG_PATH="$HOME/.config/ripgrep/ripgreprc"
command -v starship &>/dev/null && eval "$(starship init zsh)"

# -------------
# Prompt tweaks
# -------------

_prompt_newline() {
  if [[ "$PROMPT_NEEDS_NEWLINE" == true ]]; then
    echo
  fi
  PROMPT_NEEDS_NEWLINE=true
}

clear() {
  PROMPT_NEEDS_NEWLINE=false
  command clear
}

PROMPT_NEEDS_NEWLINE=false
precmd_functions+=(_prompt_newline)